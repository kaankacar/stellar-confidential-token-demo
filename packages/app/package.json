{
  "name": "@ctd/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "vendor:bb": "node ../../scripts/vendor-bb.mjs",
    "predev": "pnpm vendor:bb",
    "dev": "next dev --webpack",
    "prebuild": "pnpm vendor:bb",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ctd/disclosure": "workspace:*",
    "@opennextjs/cloudflare": "^1.19.11",
    "@ctd/sdk": "workspace:*",
    "@stellar/freighter-api": "^4.1.0",
    "@stellar/stellar-sdk": "^14.2.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.0",
    "wrangler": "^4.100.0"
  }
}
